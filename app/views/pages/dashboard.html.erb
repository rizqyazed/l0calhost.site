<% content_for :screen_text, "dashboard" %>

<%= link_to "#{Current.user.username}.#{request.host_with_port}", root_url(subdomain: Current.user.username), class:"text-lg", id:"user-site" %>
<section class="border p-[1rem] flex flex-col mt-2 h-[740px] justify-start md:flex-row gap-3 md:w-[740px] md:h-auto">
    <%= form_with(model: @site, class:"md:flex-1 flex flex-col md:justify-between") do |form| %>
      <div class="w-[75%] flex flex-col gap-4">
          <div>
            <%= form.label :title, "site_title" %>
            <%= form.text_field :title %>
          </div>
          <div>
            <%= form.label :description, "site_summary" %>
            <%= form.text_field :description %>
          </div>
          <div>
            <div class="flex flex-row items-center gap-2">
              <%= form.label :folder_upload, "site_content"%>
              <p class="m-0">[i]</p>
            </div>
              <%= form.file_field :folder_upload, multiple: true, webkitdirectory: true, directory: true, class: "border block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border-0 file:bg-white hover:file:bg-blue-100" %>
          </div>
      </div>
      <div class="flex justify-between mt-[2rem]">
        <%= link_to "export", root_path %>
        <%= form.submit "publish"%>
      </div>
    <% end %>
    <div class="overflow-y-scroll md:flex-1 md:h-[540px]">
         <ol class="space-y-5">
            <% @content_blocks.each do |block| %>
              <li>
                <% if block.media_file.attached? %>
                    <% if block.media_file.content_type.start_with?("image/") %>
                        <%= image_tag block.media_file, class: "max-w-full h-auto align-top" %>
                    <% elsif block.media_file.content_type.start_with?("text/") %>
                      <div class="align-top prose border p-5">
                        <% safe_text = block.media_file.download.force_encoding('UTF-8').scrub  %>
                          <%= truncate(safe_text, length: 40, separator: ' ') %>
                      </div>
                    <% end %>
                <% else %>
                  <p class="text-gray-500">nothing...</p>
                <% end %>
              </li>
            <% end %>
         </ol> 
     </div>
</section>
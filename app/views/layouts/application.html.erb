<!DOCTYPE html>
<html lang="en" class="text-[125%]">
  <head>
    <title><%= content_for(:title) || "l0calhost" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="L0calhost">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

  </head>

  <body class="md:overflow-hidden">
    <nav class="sticky w-full flex flex-row">
      <%= link_to "directory", directory_path unless current_page?(directory_path) %>
      <div class="ml-auto flex flex-row gap-">
        <%= button_to "log_out", session_path, method: :delete if authenticated? %>
        <%= link_to "log_in", new_session_path if not authenticated? unless current_page?(root_path) || current_page?(new_session_path) %>
    </div>
    </nav>
    <div class="flex flex-col justify-center mt-[5rem] gap-[5rem] items-center md:mt-0 md:flex-row md:h-screen md:gap-0 ">
      <header class="flex-1 text-center md:sticky">
        <h1 class="m-0 text-xl font-normal">
          <%= status_screen_text(@site || @content_block) %>
        </h1>
        <pre class="m-0">
____________________
|  |              |  |
|[]|              |[]|
|  |              |  |
|  |              |  |
|  |              |  |
|  |______________|  |
|                    |
|     ____________   |
|    | __      |  |  |
|    ||  |     |  |  |
|    ||__|     |  |  |
.____|_________|__|__|
        </pre>
        <p class="m-0">
          <%= link_to "<-- back", root_path unless current_page?(dashboard_path) || current_page?(root_path) %>
          <%= link_to "settings", root_path if current_page?(dashboard_path) %>
        </p>
      </header>
      <main class="flex-2 w-full h-full flex flex-col justify-center">
          <%= yield %>
      </main>
    </div>
  </body>
</html>
